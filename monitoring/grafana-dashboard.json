{
  "title": "Credit Risk Monitoring 🚀",
  "schemaVersion": 36,
  "version": 4,
  "refresh": "5s",
  "panels": [
    {
      "type": "row",
      "title": "💼 Visão de Negócio (Business KPIs)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "type": "gauge",
      "title": "Taxa de Aprovação (Approval Rate)",
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 1},
      "targets": [{"expr": "credit_business_approval_rate"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.7}]}
        }
      }
    },
    {
      "type": "gauge",
      "title": "Taxa de Alto Risco (High Risk Rate)",
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 1},
      "targets": [{"expr": "credit_business_high_risk_rate"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.2}, {"color": "red", "value": 0.4}]}
        }
      }
    },
    {
      "type": "gauge",
      "title": "Probabilidade Média de Default",
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 1},
      "targets": [{"expr": "credit_business_avg_default_probability"}],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "unit": "percentunit",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.3}, {"color": "red", "value": 0.6}]}
        }
      }
    },
    {
      "type": "row",
      "title": "🤖 Saúde do Modelo & Data Drift",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 8}
    },
    {
      "type": "stat",
      "title": "Total de Predições",
      "gridPos": {"h": 9, "w": 4, "x": 0, "y": 9},
      "targets": [{"expr": "sum(credit_model_predictions_total)"}],
      "fieldConfig": {
        "defaults": {"color": {"mode": "background", "fixedColor": "blue"}}
      }
    },
    {
      "type": "timeseries",
      "title": "Distribuição de Probabilidades (Model Output)",
      "gridPos": {"h": 9, "w": 12, "x": 4, "y": 9},
      "targets": [{"expr": "rate(credit_model_prediction_probability_bucket[$__rate_interval])", "legendFormat": "Bucket {{le}}"}],
      "options": {
        "custom": {"fillOpacity": 30, "stacking": {"mode": "normal", "group": "A"}},
        "legend": {"displayMode": "table", "placement": "right"}
      }
    },
    {
      "type": "bargauge",
      "title": "Data Drift (PSI) por Feature",
      "description": "PSI < 0.1 (OK), 0.1 - 0.2 (Atenção), > 0.2 (Drift Grave)",
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 9},
      "targets": [{"expr": "credit_drift_psi", "legendFormat": "{{feature}}"}],
      "options": {"orientation": "horizontal", "displayMode": "gradient"},
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 0.5,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 0.2}]}
        }
      }
    },
    {
      "type": "row",
      "title": "⚙️ Saúde do Sistema e Segurança (API)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}
    },
    {
      "type": "timeseries",
      "title": "Requisições da API (Por Endpoint)",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19},
      "targets": [{"expr": "sum by (endpoint) (rate(credit_api_requests_total[$__rate_interval]))", "legendFormat": "{{endpoint}}"}],
      "options": {"custom": {"fillOpacity": 15, "lineWidth": 2}}
    },
    {
      "type": "timeseries",
      "title": "Latência P95",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(credit_api_request_duration_seconds_bucket[$__rate_interval])) by (le))", "legendFormat": "p95 Latency"}],
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}}
    },
    {
      "type": "timeseries",
      "title": "Eventos de Segurança Guardrails",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19},
      "targets": [{"expr": "rate(credit_security_events_total[$__rate_interval])", "legendFormat": "{{event_type}}"}],
      "options": {"custom": {"fillOpacity": 60, "lineWidth": 0, "stacking": {"mode": "normal", "group": "A"}}}
    }
  ]
}
